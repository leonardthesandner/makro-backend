# PostgreSQL – wird von Railway automatisch gesetzt
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic – für Text-Parsing
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# USDA FoodData Central – kostenlos
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=DEMO_KEY

# Geheimes Passwort zwischen App und Backend
# Beliebiger langer String, z.B.: openssl rand -hex 32
APP_SECRET=dein-geheimes-passwort-hier

# Wird von Railway automatisch gesetzt
NODE_ENV=production
PORT=3000
